# =============================================
# YOUR SHOPFRONT — Environment Variables
# Copy to .env.local and fill in real values.
# =============================================

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — keys + price IDs (Phase 4)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Subscription tier — $499 setup (one-time) + $199/mo (recurring)
STRIPE_PRICE_SUBSCRIPTION_SETUP=price_xxx
STRIPE_PRICE_SUBSCRIPTION_MONTHLY=price_xxx
# One-time tier — $2,997 (one-time) + optional $29/mo hosting addon (recurring)
STRIPE_PRICE_ONETIME=price_xxx
STRIPE_PRICE_HOSTING_ADDON=price_xxx

# Resend — transactional email
# Without RESEND_API_KEY + CONTACT_INBOX_EMAIL set, /api/contact still
# returns {ok:true} but only console.log's the inbound message.
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Your Shopfront <onboarding@resend.dev>
CONTACT_INBOX_EMAIL=stub@example.com

# Slack — real-time lead notifications (optional)
# Skipped silently if not set.
SLACK_WEBHOOK_URL=

# Cloudflare — DNS for *.yourshopfront.com customer subdomains (Phase 5).
# Token needs Zone:DNS:Edit scoped to the yourshopfront.com zone only.
CLOUDFLARE_API_TOKEN=xxx
CLOUDFLARE_ZONE_ID=xxx

# Vercel — domain attach/detach for the apex-sites project (Phase 5).
# VERCEL_PROJECT_ID is THIS project's id; the orchestrator attaches each
# customer subdomain to it (multi-tenant single-project model).
VERCEL_API_TOKEN=xxx
VERCEL_TEAM_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx

# Apex domain — the root the orchestrator builds subdomains under.
# Defaults to "yourshopfront.com" if unset.
APEX_DOMAIN=yourshopfront.com

# Cron auth — Vercel cron sends Authorization: Bearer ${CRON_SECRET}.
# Set this on Vercel and it auto-injects on cron-triggered requests.
CRON_SECRET=changeme

# Supabase — customer + site records (Phase 4)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Admin
ADMIN_PASSWORD=changeme

# Sales-agent chat — Anthropic Claude Haiku 4.5 (claude-haiku-4-5-20251001)
# Without ANTHROPIC_API_KEY set, /api/chat returns 503 and the bubble shows an
# "offline" error to the user. The bubble itself still renders.
ANTHROPIC_API_KEY=sk-ant-xxx

# Plausible analytics — leave NEXT_PUBLIC_PLAUSIBLE_DOMAIN empty to disable
# (component returns null and no script is loaded).
# NEXT_PUBLIC_PLAUSIBLE_HOST defaults to https://plausible.io if unset; override
# for self-hosted Plausible installs.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_HOST=
