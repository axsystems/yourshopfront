# =============================================================================
# Your Shopfront — production environment variables
# =============================================================================
# This file documents every variable a production Vercel deploy needs.
# Copy to your Vercel project's Environment Variables (Production scope).
# Never check secrets into the repo — `.env.local` is gitignored; this file
# only documents shapes, not values.
#
# Where to find each value: see comments next to each entry.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Used by: src/app/layout.tsx, src/lib/seo.ts, /api/checkout success_url,
# /api/stripe/webhook welcome email, /api/og fallback. Must match the
# canonical production domain exactly (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://yourshopfront.com

# -----------------------------------------------------------------------------
# Stripe — live-mode keys
# -----------------------------------------------------------------------------
# Where: dashboard.stripe.com → Developers → API keys (toggle to LIVE mode).
# DO NOT use sk_test_* in production — the webhook signature verification
# will reject events from the wrong mode.
STRIPE_SECRET_KEY=sk_live_REPLACE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE

# Stripe webhook secret. Different from the test-mode whsec_*.
# Where: dashboard.stripe.com → Developers → Webhooks → your live endpoint
# at https://yourshopfront.com/api/stripe/webhook → "Reveal signing secret".
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# Stripe price IDs (live-mode). Run `pnpm stripe:setup` against a live key
# to create the four products idempotently and emit these lines.
STRIPE_PRICE_SUBSCRIPTION_SETUP=price_REPLACE
STRIPE_PRICE_SUBSCRIPTION_MONTHLY=price_REPLACE
STRIPE_PRICE_ONETIME=price_REPLACE
STRIPE_PRICE_HOSTING_ADDON=price_REPLACE

# -----------------------------------------------------------------------------
# Supabase — production project
# -----------------------------------------------------------------------------
# Where: app.supabase.com → your production project → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY is server-only and bypasses RLS — never expose
# in a public env (no NEXT_PUBLIC_ prefix on this one).
SUPABASE_URL=https://REPLACE.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ_SERVICE_ROLE_KEY_REPLACE
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_ANON_KEY_REPLACE

# -----------------------------------------------------------------------------
# Resend — transactional email
# -----------------------------------------------------------------------------
# Where: resend.com → API keys.
# Use a domain-verified sender (yourshopfront.com) for production. Until DNS
# records (SPF, DKIM) are validated in Resend, fall back to the default
# `Your Shopfront <onboarding@resend.dev>` which works without verification but
# routes through Resend's shared subdomain.
RESEND_API_KEY=re_REPLACE
RESEND_FROM_EMAIL=Your Shopfront <hello@yourshopfront.com>
CONTACT_INBOX_EMAIL=hello@yourshopfront.com

# -----------------------------------------------------------------------------
# Slack — real-time lead notifications (optional)
# -----------------------------------------------------------------------------
# Where: api.slack.com/apps → Incoming Webhooks → New webhook.
# If unset, lead/sale notifications silently no-op.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE

# -----------------------------------------------------------------------------
# Plausible analytics — privacy-respecting, cookie-free
# -----------------------------------------------------------------------------
# When NEXT_PUBLIC_PLAUSIBLE_DOMAIN is unset, the analytics component
# returns null and no script is loaded. Set to yourshopfront.com on production.
# Override NEXT_PUBLIC_PLAUSIBLE_HOST for self-hosted Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourshopfront.com
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# -----------------------------------------------------------------------------
# Future (Phase 5+ provisioning) — not currently consumed
# -----------------------------------------------------------------------------
# Cloudflare DNS for *.yourshopfront.com customer subdomains.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# Vercel API for spinning up new customer projects.
# VERCEL_API_TOKEN=
# VERCEL_TEAM_ID=team_
# VERCEL_TEMPLATE_PROJECT_ID=prj_

# Admin password (Phase 5+ admin dashboard).
# ADMIN_PASSWORD=
